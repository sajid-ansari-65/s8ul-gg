{
  "framework": "nextjs",
  "regions": ["bom1", "sin1", "iad1", "lhr1"],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/graphql/:path*",
      "destination": "${NEXT_PUBLIC_WP_GRAPHQL_URL}/:path*"
    }
  ]
}
